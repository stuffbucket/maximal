{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/*.ts",
    "tests/**/*.test.ts"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignoreDependencies": [
    "prettier-plugin-packagejson",
    "electron",
    "undici",
    "@stryker-mutator/command-runner"
  ],
  "ignoreBinaries": [
    "trufflehog"
  ],
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "src/lib/token.ts"
  ]
}
