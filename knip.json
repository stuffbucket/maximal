{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/*.ts",
    "tests/**/*.test.ts"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignore": [
    "src/pages/**",
    "src/lib/build-info.gen.ts",
    "src/pages/usage-viewer.gen.ts"
  ],
  "ignoreDependencies": [
    "prettier-plugin-packagejson",
    "electron",
    "undici"
  ],
  "ignoreBinaries": [
    "publish"
  ],
  "ignoreExportsUsedInFile": true
}
