{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/*.ts",
    "tests/**/*.test.ts"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignoreDependencies": [
    "prettier-plugin-packagejson",
    "electron",
    "undici",
    "@stryker-mutator/command-runner",
    "@stryker-mutator/core",
    "bumpp",
    "eslint",
    "lint-staged",
    "oxlint"
  ],
  "ignoreBinaries": [
    "bumpp",
    "depcruise",
    "eslint",
    "knip-bun",
    "oxlint",
    "simple-git-hooks",
    "stryker",
    "trufflehog",
    "tsc"
  ],
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "src/lib/token.ts"
  ]
}
