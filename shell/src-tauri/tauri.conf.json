{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maximal",
  "version": "0.0.0",
  "identifier": "co.stuffbucket.maximal",
  "build": {
    "beforeDevCommand": "cd .. && bun run build:ui",
    "beforeBuildCommand": "cd .. && bun run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/maximal"],
    "macOS": {
      "exceptionDomain": "localhost"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
