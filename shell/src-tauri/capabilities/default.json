{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Tray + settings/dashboard/splash/update-confirm window permissions",
  "windows": ["settings", "dashboard", "splash", "update-confirm"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "opener:default",
    "notification:default",
    "default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/maximal",
          "sidecar": true,
          "args": [
            "start",
            "--replace",
            "--port",
            { "validator": "^\\d{2,5}$" }
          ]
        }
      ]
    }
  ]
}
