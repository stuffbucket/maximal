{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Tray + settings/dashboard/splash window permissions",
  "windows": ["settings", "dashboard", "splash"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "notification:default",
    "default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/maximal",
          "sidecar": true,
          "args": ["start", "--replace", "--port", { "validator": "^\\d{2,5}$" }]
        }
      ]
    }
  ]
}
