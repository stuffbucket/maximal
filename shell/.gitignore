# Tauri build output (~75 MB), regenerated by `bunx tauri build`.
src-tauri/target/

# Sidecar binary built by `bun build --compile`. Per-host-triple,
# regenerated; not source. Real release builds put this under
# `binaries/` from CI, not from the local checkout.
src-tauri/binaries/

# Generated by tauri-build (Cargo build script) — schemas + capability
# permission JSONs. Not source.
src-tauri/gen/
