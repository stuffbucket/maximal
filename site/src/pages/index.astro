---
import "../styles/global.css";
import StarNest from "../components/StarNest.astro";
import FlyingToasters from "../components/FlyingToasters.astro";

const REPO = "stuffbucket/maximal";
const REPO_URL = `https://github.com/${REPO}`;
const RELEASES_URL = `${REPO_URL}/releases`;

interface ReleaseInfo {
  tag: string | null;
  hasRelease: boolean;
}

async function fetchLatestTag(): Promise<ReleaseInfo> {
  try {
    const res = await fetch(
      `https://api.github.com/repos/${REPO}/releases/latest`,
      {
        headers: {
          Accept: "application/vnd.github+json",
          "User-Agent": "maximal-site-build",
        },
      },
    );
    if (res.status === 404) return { tag: null, hasRelease: false };
    if (!res.ok) return { tag: null, hasRelease: false };
    const body = (await res.json()) as { tag_name?: string };
    if (typeof body.tag_name === "string" && body.tag_name.length > 0) {
      return { tag: body.tag_name, hasRelease: true };
    }
    return { tag: null, hasRelease: false };
  } catch {
    return { tag: null, hasRelease: false };
  }
}

const { tag, hasRelease } = await fetchLatestTag();

const assetUrl = (filename: string): string =>
  hasRelease && tag
    ? `${REPO_URL}/releases/download/${tag}/${filename}`
    : RELEASES_URL;

const versionForAsset = tag ?? "latest";
const macDmgFile = `maximal-${versionForAsset}-darwin-arm64.dmg`;
const winMsiFile = `maximal-${versionForAsset}-windows-x64.msi`;
const sourceTarFile = `maximal-${versionForAsset}-darwin-arm64.tar.gz`;
const sourceZipFile = `maximal-${versionForAsset}-windows-x64.zip`;
const macDmg = assetUrl(macDmgFile);
const winMsi = assetUrl(winMsiFile);
const winPs1 = assetUrl(`install.ps1`);
const sourceTarGz = assetUrl(sourceTarFile);
const sourceZip = assetUrl(sourceZipFile);

const versionLabel = hasRelease && tag ? tag : "see /releases";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>maximal — All your AI coding tools, one Copilot subscription</title>
    <meta
      name="description"
      content="Connect Claude Code, Codex, opencode, and more to your existing GitHub Copilot subscription with maximal."
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`}
    />
    <meta name="theme-color" content="#0f2e3d" />
    <meta name="color-scheme" content="dark" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Background: Star Nest fragment shader (deepest layer) -->
    <StarNest />
    <!-- Mid layer: After Dark Flying Toasters sprites -->
    <FlyingToasters />

    <main id="main">
      <!-- HERO — scarlet -->
      <header class="card card--scarlet hero" aria-labelledby="title">
        <svg
          class="hero-ornament hero-ornament--tr"
          viewBox="0 0 64 64"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M32 2 L36 28 L62 32 L36 36 L32 62 L28 36 L2 32 L28 28 Z" />
        </svg>
        <svg
          class="hero-ornament hero-ornament--bl"
          viewBox="0 0 64 64"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M4 4 L4 20 M4 4 L20 4" />
          <path d="M60 60 L60 44 M60 60 L44 60" />
          <circle cx="32" cy="32" r="6" />
        </svg>
        <h1 id="title" class="wordmark">maximal</h1>
        <p class="tagline">
          Copilot, Claude and Codex<br />walked into a taskbar…
        </p>
        <div class="header-meta">
          <a href={REPO_URL} rel="noopener">github.com/{REPO}</a>
          <span aria-hidden="true">·</span>
          <a href={RELEASES_URL} rel="noopener">latest: {versionLabel}</a>
        </div>
      </header>

      <!-- WHAT — turquoise -->
      <section
        id="what"
        class="card card--turquoise"
        aria-labelledby="what-h"
      >
        <svg
          class="section-ornament"
          viewBox="0 0 48 48"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path d="M24 4 Q 36 16, 24 28 Q 12 16, 24 4 Z" />
          <path d="M24 20 Q 36 32, 24 44 Q 12 32, 24 20 Z" />
        </svg>
        <h2 id="what-h">What is this</h2>
        <p>
          You already have a GitHub Copilot subscription? Of course you
          do. Connect Claude Code, Codex, opencode, and more to your
          existing GitHub Copilot subscription with <span class="brand"
            >maximal</span
          >.
        </p>
        <p>
          Use Claude Code, Codex, Copilot Chat, opencode: or whatever
          the cool kids make tomorrow. Run them all, or switch to
          something new using <span class="brand">maximal</span>.
        </p>
      </section>

      <!-- DOWNLOAD — magenta -->
      <section
        id="download"
        class="card card--magenta"
        aria-labelledby="download-h"
      >
        <svg
          class="section-ornament"
          viewBox="0 0 48 48"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M24 4 L27 21 L44 24 L27 27 L24 44 L21 27 L4 24 L21 21 Z" />
        </svg>
        <h2 id="download-h">Download</h2>
        <p class="section-note" id="download-note">
          Click the installer for you, or a copy for a friend. We'll
          show you what to do with it once the download starts.
        </p>

        <div class="downloads" role="group" aria-label="Downloads by platform">
          <a
            class="btn"
            data-os="mac"
            data-installer="mac-app"
            href={macDmg}
            rel="noopener"
          >
            <span class="btn-label">
              <svg
                class="btn-spark"
                viewBox="0 0 22 22"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M11 1 L13 9 L21 11 L13 13 L11 21 L9 13 L1 11 L9 9 Z" />
              </svg>
              <span>macOS — Apple Silicon</span>
            </span>
            <span class="btn-meta">.dmg</span>
          </a>
          <a
            class="btn"
            data-os="windows"
            data-installer="windows-msi"
            href={winMsi}
            rel="noopener"
          >
            <span class="btn-label">
              <svg
                class="btn-spark"
                viewBox="0 0 22 22"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M11 1 L13 9 L21 11 L13 13 L11 21 L9 13 L1 11 L9 9 Z" />
              </svg>
              <span>Windows installer</span>
            </span>
            <span class="btn-meta">.msi</span>
          </a>
          <a
            class="btn"
            data-os="windows"
            data-installer="windows-ps1"
            href={winPs1}
            rel="noopener"
          >
            <span class="btn-label"
              ><span>Windows PowerShell installer</span></span
            >
            <span class="btn-meta">install.ps1</span>
          </a>
          <a
            class="btn"
            data-os="mac"
            data-installer="source-mac"
            href={sourceTarGz}
            rel="noopener"
          >
            <span class="btn-label"><span>macOS — CLI</span></span>
            <span class="btn-meta">.tar.gz</span>
          </a>
          <a
            class="btn"
            data-os="windows"
            data-installer="source-win"
            href={sourceZip}
            rel="noopener"
          >
            <span class="btn-label"><span>Windows — CLI</span></span>
            <span class="btn-meta">.zip</span>
          </a>
          <a
            class="btn"
            data-os="mac"
            data-installer="homebrew"
            href="https://github.com/stuffbucket/homebrew-tap"
            rel="noopener"
          >
            <span class="btn-label"><span>Homebrew — macOS / Linux</span></span>
            <span class="btn-meta">brew install</span>
          </a>
          <a
            class="btn btn--read-my-mind"
            data-read-my-mind
            href={macDmg}
            rel="noopener"
          >
            <span class="btn-label">
              <svg
                class="btn-spark"
                viewBox="0 0 22 22"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M11 1 L13 9 L21 11 L13 13 L11 21 L9 13 L1 11 L9 9 Z" />
              </svg>
              <span>Read my mind</span>
            </span>
            <span class="btn-meta" data-read-my-mind-meta>we'll guess</span>
          </a>
        </div>

        <div class="install-hint" data-installer-hint="mac-app" hidden>
          <p class="section-note">
            <strong>What to do with it:</strong> double-click the
            <code>.dmg</code> to open it, then drag
            <code>maximal.app</code> onto the Applications shortcut.
            Eject the disk image and you're done.
          </p>
        </div>
        <div class="install-hint" data-installer-hint="windows-msi" hidden>
          <p class="section-note">
            <strong>What to do with it:</strong> double-click the
            <code>.msi</code> to install. SmartScreen will warn you the
            first time — see the warning below.
          </p>
        </div>
        {
          hasRelease && (
            <div class="install-hint" data-installer-hint="windows-ps1" hidden>
              <p class="section-note">
                <strong>What to do with it:</strong> copy/paste into a
                terminal, Claude Code CLI, or Copilot CLI.
              </p>
              <div class="copyable">
                <code class="ps-cmd">iex (irm {winPs1})</code>
                <button
                  class="copy-btn"
                  type="button"
                  aria-label="Copy command"
                >
                  <svg
                    class="copy-btn__icon"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                  >
                    <rect x="5" y="5" width="9" height="9" rx="1.5" />
                    <path d="M11 5 V3 a1 1 0 0 0 -1 -1 H3 a1 1 0 0 0 -1 1 v7 a1 1 0 0 0 1 1 h2" />
                  </svg>
                  <span class="copy-btn__label">Copy</span>
                </button>
              </div>
            </div>
          )
        }
        <div class="install-hint" data-installer-hint="source-mac" hidden>
          <p class="section-note">
            <strong>What to do with it:</strong> copy/paste into a
            terminal, Claude Code CLI, or Copilot CLI.
          </p>
          <div class="copyable">
            <code class="ps-cmd">tar -xzf {sourceTarFile} && ./maximal --help</code>
            <button class="copy-btn" type="button" aria-label="Copy command">
              <svg
                class="copy-btn__icon"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="5" y="5" width="9" height="9" rx="1.5" />
                <path d="M11 5 V3 a1 1 0 0 0 -1 -1 H3 a1 1 0 0 0 -1 1 v7 a1 1 0 0 0 1 1 h2" />
              </svg>
              <span class="copy-btn__label">Copy</span>
            </button>
          </div>
        </div>
        <div class="install-hint" data-installer-hint="homebrew" hidden>
          <p class="section-note">
            <strong>What to do with it:</strong> copy/paste into a
            terminal, Claude Code CLI, or Copilot CLI.
          </p>
          <div class="copyable">
            <code class="ps-cmd">brew install stuffbucket/tap/maximal</code>
            <button class="copy-btn" type="button" aria-label="Copy command">
              <svg
                class="copy-btn__icon"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="5" y="5" width="9" height="9" rx="1.5" />
                <path d="M11 5 V3 a1 1 0 0 0 -1 -1 H3 a1 1 0 0 0 -1 1 v7 a1 1 0 0 0 1 1 h2" />
              </svg>
              <span class="copy-btn__label">Copy</span>
            </button>
          </div>
        </div>
        <div class="install-hint" data-installer-hint="source-win" hidden>
          <p class="section-note">
            <strong>What to do with it:</strong> extract the
            <code>.zip</code> and run <code>maximal.exe</code> from
            a PowerShell prompt in the extracted folder. No installer.
          </p>
        </div>
      </section>

      <!-- WARN — ochre callout -->
      <section id="warn" class="card card--ochre" aria-labelledby="warn-h">
        <h2 id="warn-h">First-launch warning</h2>
        <div class="callout" role="note">
          <svg
            class="callout-icon"
            viewBox="0 0 40 40"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M20 2 L23 14 L36 16 L26 24 L29 36 L20 30 L11 36 L14 24 L4 16 L17 14 Z" />
          </svg>
          <div>
            <p>
              <strong>macOS bundles are signed and notarized.</strong>
              Windows builds aren't yet — like plenty of apps you've
              already installed, SmartScreen will throw an "are you
              sure?" on first launch. Click through once and you're
              set.
            </p>
            <p data-installer="mac-app">
              <strong>macOS:</strong> nothing to click through. The
              <code>.dmg</code> is signed and notarized by Apple, so
              the app launches like any other Mac app — drag, eject,
              double-click.
            </p>
            <p data-installer="source-mac" hidden>
              <strong>macOS:</strong> macOS quarantines downloaded
              binaries. Either approve once in <strong
                >System Settings → Privacy &amp; Security → Open Anyway</strong
              >, or strip the flag from a Terminal:
              <code>xattr -dr com.apple.quarantine ./maximal</code>.
            </p>
            <p data-installer="windows-msi" hidden>
              <strong>Windows:</strong> SmartScreen will say "Windows
              protected your PC" on the <code>.msi</code>. Click
              <strong>More info</strong>, then <strong>Run anyway</strong>.
            </p>
            <p data-installer="windows-ps1" hidden>
              <strong>Windows:</strong> SmartScreen will flag the
              <code>.ps1</code>. Click <strong>More info → Run anyway</strong>.
              If PowerShell's execution policy rejects the script, run it
              with <code>powershell -ExecutionPolicy Bypass -File install.ps1</code>.
            </p>
            <p data-installer="homebrew" hidden>
              <strong>Homebrew:</strong> nothing to click through.
              Brew strips the quarantine flag on install, so the binary
              just runs.
            </p>
            <p data-installer="source-win" hidden>
              <strong>Windows:</strong> SmartScreen will block the first
              run of <code>maximal.exe</code>. Right-click →
              <strong>Properties → Unblock</strong>, or click
              <strong>More info → Run anyway</strong>.
            </p>
          </div>
        </div>
      </section>

      <!-- SETUP — indigo -->
      <section id="setup" class="card card--indigo" aria-labelledby="setup-h">
        <h2 id="setup-h">Setup</h2>
        <div class="setup-picker">
          <label for="setup-installer">Setting up on</label>
          <select id="setup-installer" data-setup-installer>
            <option value="mac-app">macOS — DMG installer (.dmg)</option>
            <option value="source-mac">macOS — CLI tarball (.tar.gz)</option>
            <option value="windows-msi">Windows — installer (.msi)</option>
            <option value="windows-ps1">Windows — PowerShell installer</option>
            <option value="source-win">Windows — CLI zip</option>
            <option value="homebrew">Homebrew (macOS / Linux)</option>
          </select>
        </div>
        <ol class="steps">
          <li>
            <strong>Install.</strong>
            <span data-installer="mac-app">
              Double-click the <code>.dmg</code> to mount it, drag
              <code>maximal.app</code> onto the Applications shortcut,
              and eject the disk image.
            </span>
            <span data-installer="source-mac" hidden>
              Extract the tarball:
              <code>tar -xzf {sourceTarFile}</code>. The binary is
              <code>./maximal</code> — run it from there or symlink it
              onto your <code>PATH</code>.
            </span>
            <span data-installer="windows-msi" hidden>
              Double-click the <code>.msi</code> and step through the
              installer. It puts <code>maximal</code> on your
              <code>PATH</code>.
            </span>
            <span data-installer="windows-ps1" hidden>
              Right-click <code>install.ps1</code> and choose
              <em>Run with PowerShell</em>, or use the one-liner shown in
              the Download section above to install in one step.
            </span>
            <span data-installer="source-win" hidden>
              Extract the <code>.zip</code>. <code>maximal.exe</code>
              is at the root of the extracted folder — run it from
              there, or add the folder to your <code>PATH</code>.
            </span>
            <span data-installer="homebrew" hidden>
              From any terminal, run
              <code>brew install stuffbucket/tap/maximal</code>. Brew
              handles the tap, the binary, and PATH for you.
            </span>
          </li>
          <li>
            <strong>Authenticate.</strong>
            <span data-platform="mac">
              Open <strong>Terminal</strong> and run the one-time GitHub
              device-code flow. This is the only required terminal step.
            </span>
            <span data-platform="windows" hidden>
              Open <strong>PowerShell</strong> and run the one-time
              GitHub device-code flow. This is the only required
              terminal step.
            </span>
            <div class="copyable copyable--block">
              <pre><code data-setup-cmd>maximal setup</code></pre>
              <button class="copy-btn" type="button" aria-label="Copy command">
                <svg
                  class="copy-btn__icon"
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <rect x="5" y="5" width="9" height="9" rx="1.5" />
                  <path d="M11 5 V3 a1 1 0 0 0 -1 -1 H3 a1 1 0 0 0 -1 1 v7 a1 1 0 0 0 1 1 h2" />
                </svg>
                <span class="copy-btn__label">Copy</span>
              </button>
            </div>
          </li>
          <li>
            <strong>Point your client at it.</strong> The proxy listens on
            <code>localhost:4141</code>. Configure Claude Code or Codex with
            that base URL — see the
            <a href={`${REPO_URL}#run`} rel="noopener">README</a> for client
            snippets.
          </li>
        </ol>
      </section>

      <!-- FOOTER — console -->
      <footer
        id="footer"
        class="card card--console site-footer"
        aria-label="Site footer"
      >
        <span>
          MIT license ·
          <a href={`${REPO_URL}/blob/main/LICENSE`} rel="noopener">LICENSE</a>
          ·
          <a href={`${REPO_URL}/blob/main/THIRD-PARTY-LICENSE`} rel="noopener"
            >third-party</a
          >
        </span>
        <a href={REPO_URL} rel="noopener">github.com/{REPO}</a>
      </footer>
    </main>

    <!-- Foreground layer: bottom-pinned glass dock -->
    <nav class="dock" aria-label="Page sections">
      <div class="dock-inner">
        <span class="dock-brand">maximal</span>
        <a href="#what">What</a>
        <a href="#download">Download</a>
        <a href="#warn">Launch</a>
        <a href="#setup">Setup</a>
        <a href={REPO_URL} rel="noopener">GitHub</a>
      </div>
    </nav>

    <script is:inline>
      // OS detection + installer-keyed UX. Download buttons are plain
      // single-click links. On click, the install hint, Setup picker,
      // Setup steps, Authenticate command, and First-launch warning
      // all switch to the variant matching the clicked download.
      (function () {
        var ua = navigator.userAgent || "";
        var platform = navigator.platform || "";
        var isMac = /Mac|iPhone|iPad|iPod/.test(ua) || /Mac/.test(platform);
        var isWindows = /Windows/.test(ua) || /Win/.test(platform);

        var defaultPlatform = isWindows ? "windows" : "mac";
        var defaultInstaller =
          defaultPlatform === "windows" ? "windows-msi" : "mac-app";

        function installerToPlatform(key) {
          if (!key) return defaultPlatform;
          return key.indexOf("mac") !== -1 ? "mac" : "windows";
        }

        var setupCmds = {
          "mac-app": "maximal setup",
          "source-mac": "./maximal setup",
          "windows-msi": "maximal setup",
          "windows-ps1": "maximal setup",
          "source-win": ".\\maximal.exe setup",
          homebrew: "maximal setup",
        };

        // Wire "Read my mind" to the detected primary installer.
        var rmm = document.querySelector("[data-read-my-mind]");
        var rmmMeta = document.querySelector("[data-read-my-mind-meta]");
        var primary = document.querySelector(
          '.btn[data-installer="' + defaultInstaller + '"]',
        );
        if (rmm && primary) {
          rmm.href = primary.getAttribute("href");
          rmm.setAttribute("data-installer", defaultInstaller);
          if (rmmMeta) {
            rmmMeta.textContent =
              defaultPlatform === "windows" ? "Windows" : "macOS";
          }
        }
        // Subtle highlight on the OS-detected primary.
        if (primary) primary.classList.add("btn--primary");

        var setupSelect = document.querySelector("[data-setup-installer]");
        var setupCmdEl = document.querySelector("[data-setup-cmd]");

        function selectVariant(installer) {
          if (!installer) return;
          var plat = installerToPlatform(installer);

          // Per-installer install hints in the Download section.
          document
            .querySelectorAll("[data-installer-hint]")
            .forEach(function (h) {
              h.hidden = h.getAttribute("data-installer-hint") !== installer;
            });
          // Per-installer content (Setup install step + warning text).
          document.querySelectorAll("[data-installer]").forEach(function (el) {
            // Don't touch download buttons — they keep their own
            // installer attr regardless of selection.
            if (el.classList.contains("btn")) return;
            el.hidden = el.getAttribute("data-installer") !== installer;
          });
          // Per-platform content (Authenticate phrasing).
          document.querySelectorAll("[data-platform]").forEach(function (el) {
            el.hidden = el.getAttribute("data-platform") !== plat;
          });
          // Authenticate command.
          if (setupCmdEl)
            setupCmdEl.textContent =
              setupCmds[installer] || "maximal setup";
          // Sync picker.
          if (setupSelect && setupSelect.value !== installer)
            setupSelect.value = installer;
        }

        selectVariant(defaultInstaller);

        if (setupSelect) {
          setupSelect.addEventListener("change", function () {
            selectVariant(setupSelect.value);
          });
        }

        var btns = document.querySelectorAll(
          ".btn[data-installer], [data-read-my-mind]",
        );
        btns.forEach(function (btn) {
          btn.addEventListener("click", function (e) {
            var key = btn.getAttribute("data-installer");
            if (!key) return;
            // Homebrew has no file to download — staying on the page
            // so the user can copy the brew command is more useful
            // than navigating to the tap README.
            if (key === "homebrew") e.preventDefault();
            selectVariant(key);
          });
        });
      })();

      // Copy-to-clipboard for .copyable blocks.
      (function () {
        var blocks = document.querySelectorAll(".copyable");
        blocks.forEach(function (block) {
          var btn = block.querySelector(".copy-btn");
          var src = block.querySelector("code");
          if (!btn || !src) return;
          var label = btn.querySelector(".copy-btn__label");
          var resetTimer = 0;
          btn.addEventListener("click", function () {
            var text = (src.textContent || "").trim();
            var done = function () {
              btn.classList.add("copy-btn--copied");
              if (label) label.textContent = "Copied";
              if (resetTimer) clearTimeout(resetTimer);
              resetTimer = window.setTimeout(function () {
                btn.classList.remove("copy-btn--copied");
                if (label) label.textContent = "Copy";
              }, 1500);
            };
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(text).then(done, function () {});
            } else {
              var ta = document.createElement("textarea");
              ta.value = text;
              ta.setAttribute("readonly", "");
              ta.style.position = "fixed";
              ta.style.opacity = "0";
              document.body.appendChild(ta);
              ta.select();
              try {
                document.execCommand("copy");
                done();
              } catch (e) {}
              document.body.removeChild(ta);
            }
          });
        });
      })();

      // aria-current on dock links based on viewport scroll position.
      (function () {
        var links = document.querySelectorAll('.dock a[href^="#"]');
        if (!links.length || !("IntersectionObserver" in window)) return;
        var byId = {};
        links.forEach(function (a) {
          var id = a.getAttribute("href").slice(1);
          byId[id] = a;
        });
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              var a = byId[entry.target.id];
              if (!a) return;
              if (entry.isIntersecting) {
                links.forEach(function (l) {
                  l.removeAttribute("aria-current");
                });
                a.setAttribute("aria-current", "page");
              }
            });
          },
          { rootMargin: "-40% 0px -50% 0px", threshold: 0 },
        );
        Object.keys(byId).forEach(function (id) {
          var el = document.getElementById(id);
          if (el) io.observe(el);
        });
      })();
    </script>
  </body>
</html>
