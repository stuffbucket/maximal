---
import { getEntry, render } from "astro:content";

import GodRays from "../components/GodRays.astro";
import "../styles/global.css";

const REPO = "stuffbucket/maximal";
const REPO_URL = `https://github.com/${REPO}`;

// The landing body is authored in Markdoc (src/content/landing/index.mdoc).
// Release-dependent data (download URLs, version label) is resolved inside the
// Hero/Downloads components via the shared, memoized lib/downloads.ts — which
// wraps the unchanged lib/version.ts logic — so this shell stays presentational.
const entry = await getEntry("landing", "index");
const { Content } = await render(entry);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,400..900,0..100,0..1&display=swap"
    />

    <title>maximal — your AI tools, your Copilot models, one connection</title>
    <meta
      name="description"
      content="maximal is the easy way to connect the AI coding tools you use — Claude Code, Codex, opencode, Cursor — to the models in your GitHub Copilot subscription."
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`}
    />
    <meta
      name="theme-color"
      content="#f7f2e9"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#09090b"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="color-scheme" content="light dark" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Background: god-rays shader (dark mode only, behind all content) -->
    <GodRays />

    <main id="main">
      <Content />

      <footer
        id="footer"
        class="card card--console site-footer"
        aria-label="Site footer"
      >
        <span>
          MIT license ·
          <a href={`${REPO_URL}/blob/main/LICENSE`} rel="noopener">LICENSE</a>
          ·
          <a href={`${REPO_URL}/blob/main/THIRD-PARTY-LICENSE`} rel="noopener"
            >third-party</a
          >
        </span>
        <a href={REPO_URL} rel="noopener">github.com/{REPO}</a>
      </footer>
    </main>

    <!-- Foreground layer: bottom-pinned glass dock -->
    <nav class="dock" aria-label="Page sections">
      <div class="dock-inner">
        <span class="dock-brand">maximal</span>
        <a href="#how">Why maximal</a>
        <a href="#start">Get started</a>
        <a href={REPO_URL} rel="noopener">GitHub</a>
      </div>
    </nav>

    <script is:inline>
      // aria-current on dock links based on viewport scroll position.
      (function () {
        var links = document.querySelectorAll('.dock a[href^="#"]');
        if (!links.length || !("IntersectionObserver" in window)) return;
        var byId = {};
        links.forEach(function (a) {
          byId[a.getAttribute("href").slice(1)] = a;
        });
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              var a = byId[entry.target.id];
              if (!a) return;
              if (entry.isIntersecting) {
                links.forEach(function (l) {
                  l.removeAttribute("aria-current");
                });
                a.setAttribute("aria-current", "page");
              }
            });
          },
          { rootMargin: "-40% 0px -50% 0px", threshold: 0 },
        );
        Object.keys(byId).forEach(function (id) {
          var el = document.getElementById(id);
          if (el) io.observe(el);
        });
      })();
    </script>
  </body>
</html>
