---
// Flying Toasters background — homage to After Dark's screensaver,
// re-implemented as fixed-position SVG sprites with CSS keyframes.
//
// Two trajectories so the field covers all four corners over a cycle:
//   - .--ne-sw : enters upper-right, exits lower-left (the classic).
//   - .--nw-se : enters upper-left, exits lower-right (fills the
//                otherwise-empty top-left and bottom-right bands).
//
// Each sprite has a randomized scale + duration + delay; many delays
// are NEGATIVE so on first paint sprites are scattered mid-flight
// instead of all queued off-screen.
//
// Pure CSS animation — no JS, no canvas, no ThreeJS. Toasters in
// page palette (cream chrome, golden bread, deep-teal outlines) so
// they belong with the cards.

const sprites: Array<{
  kind: "toaster" | "toast"
  dir: "ne-sw" | "nw-se"
  top: string
  duration: string
  delay: string
  scale: string
}> = [
  // UR -> LL diagonal (classic). Negative delays so sprites are
  // already mid-flight on first paint.
  { kind: "toaster", dir: "ne-sw", top: "8%",  duration: "22s", delay: "-2s",  scale: "1.0"  },
  { kind: "toast",   dir: "ne-sw", top: "18%", duration: "17s", delay: "-13s", scale: "0.7"  },
  { kind: "toaster", dir: "ne-sw", top: "32%", duration: "26s", delay: "-9s",  scale: "0.85" },
  { kind: "toast",   dir: "ne-sw", top: "44%", duration: "19s", delay: "-3s",  scale: "0.6"  },
  { kind: "toaster", dir: "ne-sw", top: "58%", duration: "24s", delay: "-19s", scale: "1.05" },
  { kind: "toast",   dir: "ne-sw", top: "70%", duration: "20s", delay: "-7s",  scale: "0.75" },
  { kind: "toaster", dir: "ne-sw", top: "82%", duration: "21s", delay: "-15s", scale: "0.95" },

  // UL -> LR diagonal (fills the corners the classic path skips).
  { kind: "toast",   dir: "nw-se", top: "5%",  duration: "23s", delay: "-6s",  scale: "0.65" },
  { kind: "toaster", dir: "nw-se", top: "22%", duration: "27s", delay: "-12s", scale: "0.9"  },
  { kind: "toast",   dir: "nw-se", top: "40%", duration: "18s", delay: "-2s",  scale: "0.7"  },
  { kind: "toaster", dir: "nw-se", top: "62%", duration: "25s", delay: "-17s", scale: "0.85" },
  { kind: "toast",   dir: "nw-se", top: "78%", duration: "16s", delay: "-9s",  scale: "0.6"  },
  { kind: "toaster", dir: "nw-se", top: "92%", duration: "29s", delay: "-22s", scale: "0.8"  },
]
---

<div class="toasters" aria-hidden="true">
  {
    sprites.map(({ kind, dir, top, duration, delay, scale }) => (
      <span
        class={`toasters__sprite toasters__sprite--${dir}`}
        style={`top:${top}; --duration:${duration}; --delay:${delay}; --scale:${scale};`}
      >
        {kind === "toaster" ? (
          <svg
            class="toasters__svg toasters__svg--toaster"
            viewBox="0 0 170 140"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id="chrome" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#fdf6e0" />
                <stop offset="0.4" stop-color="#e6dcc2" />
                <stop offset="0.5" stop-color="#9c8e72" />
                <stop offset="0.6" stop-color="#e6dcc2" />
                <stop offset="1" stop-color="#7a6e58" />
              </linearGradient>
              <linearGradient id="slot" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#1a0a08" />
                <stop offset="0.5" stop-color="#3a1a08" />
                <stop offset="1" stop-color="#5a3010" />
              </linearGradient>
              <linearGradient id="toast-pop" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#f4cb6a" />
                <stop offset="0.5" stop-color="#d8923a" />
                <stop offset="1" stop-color="#a85f1a" />
              </linearGradient>
            </defs>

            {/* Wings — bird-style, outstretched from the body's shoulders */}
            <g class="toasters__wing toasters__wing--left">
              <path
                d="M 56 70
                   Q 30 38, 0 50
                   Q 6 60, 22 66
                   Q 8 72, 2 80
                   Q 28 78, 56 84 Z"
                fill="#f4ead4"
                opacity="0.95"
              />
              <path
                d="M 28 56 L 32 72 M 16 60 L 26 76 M 8 66 L 22 80"
                stroke="#0f2e3d"
                stroke-width="1"
                stroke-linecap="round"
                opacity="0.4"
              />
            </g>
            <g class="toasters__wing toasters__wing--right">
              <path
                d="M 114 70
                   Q 140 38, 170 50
                   Q 164 60, 148 66
                   Q 162 72, 168 80
                   Q 142 78, 114 84 Z"
                fill="#f4ead4"
                opacity="0.95"
              />
              <path
                d="M 142 56 L 138 72 M 154 60 L 144 76 M 162 66 L 148 80"
                stroke="#0f2e3d"
                stroke-width="1"
                stroke-linecap="round"
                opacity="0.4"
              />
            </g>

            {/* Toaster body — taller-than-wide-ish proportion */}
            <rect
              x="50"
              y="50"
              width="70"
              height="74"
              rx="6"
              fill="url(#chrome)"
              stroke="#0f2e3d"
              stroke-width="1.5"
            />

            {/* Two slots side by side on top */}
            <rect x="58" y="46" width="22" height="6" rx="1.5" fill="url(#slot)" />
            <rect x="90" y="46" width="22" height="6" rx="1.5" fill="url(#slot)" />

            {/* Two toast slices popping up at different heights */}
            <rect
              x="59"
              y="20"
              width="20"
              height="28"
              rx="2"
              fill="url(#toast-pop)"
              stroke="#0f2e3d"
              stroke-width="1"
            />
            {/* crust shading on left slice */}
            <path
              d="M 61 22 L 77 22"
              stroke="#a85f1a"
              stroke-width="1"
              opacity="0.6"
            />
            <rect
              x="91"
              y="28"
              width="20"
              height="20"
              rx="2"
              fill="url(#toast-pop)"
              stroke="#0f2e3d"
              stroke-width="1"
            />
            <path
              d="M 93 30 L 109 30"
              stroke="#a85f1a"
              stroke-width="1"
              opacity="0.6"
            />

            {/* Front control panel: lever + indicator dot */}
            <rect
              x="58"
              y="100"
              width="44"
              height="3"
              rx="1.5"
              fill="#0f2e3d"
              opacity="0.4"
            />
            <circle cx="98" cy="101.5" r="3.5" fill="#d4a843" stroke="#0f2e3d" stroke-width="0.8" />
            <circle cx="62" cy="113" r="2" fill="#0f2e3d" opacity="0.4" />

            {/* Bottom feet shadow */}
            <ellipse cx="85" cy="130" rx="34" ry="3" fill="#0f2e3d" opacity="0.45" />
          </svg>
        ) : (
          <svg
            class="toasters__svg toasters__svg--toast"
            viewBox="0 0 100 100"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id="bread" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#f6d27b" />
                <stop offset="0.5" stop-color="#dc923a" />
                <stop offset="1" stop-color="#9a5418" />
              </linearGradient>
            </defs>

            {/* Loaf-bread slice silhouette: domed top, straight sides + bottom */}
            <path
              d="M 14 32
                 Q 14 8, 50 8
                 Q 86 8, 86 32
                 L 86 86
                 Q 86 90, 82 90
                 L 18 90
                 Q 14 90, 14 86 Z"
              fill="url(#bread)"
              stroke="#0f2e3d"
              stroke-width="1.5"
            />

            {/* Crust shading — slightly inset darker line following the silhouette */}
            <path
              d="M 19 32
                 Q 19 13, 50 13
                 Q 81 13, 81 32"
              fill="none"
              stroke="#7a3a10"
              stroke-width="1.2"
              opacity="0.55"
            />

            {/* Butter pat — square with melt-line */}
            <rect
              x="38"
              y="38"
              width="14"
              height="11"
              rx="1.5"
              fill="#fff5cc"
              stroke="#0f2e3d"
              stroke-width="0.8"
            />
            <path
              d="M 40 49 Q 45 53, 50 49 L 50 47 L 40 47 Z"
              fill="#ffe898"
              opacity="0.85"
            />

            {/* Toast pores */}
            <circle cx="28" cy="60" r="1.5" fill="#7a3a10" opacity="0.6" />
            <circle cx="62" cy="58" r="1.3" fill="#7a3a10" opacity="0.6" />
            <circle cx="36" cy="74" r="1.5" fill="#7a3a10" opacity="0.6" />
            <circle cx="58" cy="78" r="1.2" fill="#7a3a10" opacity="0.6" />
            <circle cx="72" cy="68" r="1" fill="#7a3a10" opacity="0.6" />
            <circle cx="22" cy="78" r="1.2" fill="#7a3a10" opacity="0.6" />
          </svg>
        )}
      </span>
    ))
  }
</div>
