---
// Flying Toasters background — homage to After Dark's screensaver,
// re-implemented as fixed-position SVG sprites with CSS keyframes.
//
// Two trajectories so the field covers all four corners over a cycle:
//   - .--ne-sw : enters upper-right, exits lower-left (the classic).
//   - .--nw-se : enters upper-left, exits lower-right (fills the
//                otherwise-empty top-left and bottom-right bands).
//
// Each sprite has a randomized scale + duration + delay; many delays
// are NEGATIVE so on first paint sprites are scattered mid-flight
// instead of all queued off-screen.
//
// Pure CSS animation — no JS, no canvas, no ThreeJS. Toasters in
// page palette (cream chrome, golden bread, deep-teal outlines) so
// they belong with the cards.

const sprites: Array<{
  kind: "toaster" | "toast"
  dir: "ne-sw" | "nw-se"
  top: string
  duration: string
  delay: string
  scale: string
}> = [
  // UR -> LL diagonal (classic). Negative delays so sprites are
  // already mid-flight on first paint.
  { kind: "toaster", dir: "ne-sw", top: "8%",  duration: "22s", delay: "-2s",  scale: "1.0"  },
  { kind: "toast",   dir: "ne-sw", top: "18%", duration: "17s", delay: "-13s", scale: "0.7"  },
  { kind: "toaster", dir: "ne-sw", top: "32%", duration: "26s", delay: "-9s",  scale: "0.85" },
  { kind: "toast",   dir: "ne-sw", top: "44%", duration: "19s", delay: "-3s",  scale: "0.6"  },
  { kind: "toaster", dir: "ne-sw", top: "58%", duration: "24s", delay: "-19s", scale: "1.05" },
  { kind: "toast",   dir: "ne-sw", top: "70%", duration: "20s", delay: "-7s",  scale: "0.75" },
  { kind: "toaster", dir: "ne-sw", top: "82%", duration: "21s", delay: "-15s", scale: "0.95" },

  // UL -> LR diagonal (fills the corners the classic path skips).
  { kind: "toast",   dir: "nw-se", top: "5%",  duration: "23s", delay: "-6s",  scale: "0.65" },
  { kind: "toaster", dir: "nw-se", top: "22%", duration: "27s", delay: "-12s", scale: "0.9"  },
  { kind: "toast",   dir: "nw-se", top: "40%", duration: "18s", delay: "-2s",  scale: "0.7"  },
  { kind: "toaster", dir: "nw-se", top: "62%", duration: "25s", delay: "-17s", scale: "0.85" },
  { kind: "toast",   dir: "nw-se", top: "78%", duration: "16s", delay: "-9s",  scale: "0.6"  },
  { kind: "toaster", dir: "nw-se", top: "92%", duration: "29s", delay: "-22s", scale: "0.8"  },
]
---

<div class="toasters" aria-hidden="true">
  {
    sprites.map(({ kind, dir, top, duration, delay, scale }) => (
      <span
        class={`toasters__sprite toasters__sprite--${dir}`}
        style={`top:${top}; --duration:${duration}; --delay:${delay}; --scale:${scale};`}
      >
        {kind === "toaster" ? (
          <svg
            class="toasters__svg toasters__svg--toaster"
            viewBox="0 0 200 140"
            xmlns="http://www.w3.org/2000/svg"
          >
            {/* Wings: simple silhouettes, no inner detail — read at any size. */}
            <g class="toasters__wing toasters__wing--left">
              <path
                d="M 60 78
                   C 28 50, 8 56, 0 70
                   C 18 72, 28 78, 30 84
                   C 14 86, 6 92, 4 100
                   C 30 96, 50 92, 60 92 Z"
                fill="#f4ead4"
              />
            </g>
            <g class="toasters__wing toasters__wing--right">
              <path
                d="M 140 78
                   C 172 50, 192 56, 200 70
                   C 182 72, 172 78, 170 84
                   C 186 86, 194 92, 196 100
                   C 170 96, 150 92, 140 92 Z"
                fill="#f4ead4"
              />
            </g>

            {/* Toaster body — 80×70 with strong silhouette. Single fill,
                no busy gradient. */}
            <rect
              x="60"
              y="56"
              width="80"
              height="70"
              rx="8"
              fill="#e8dcc2"
              stroke="#0f2e3d"
              stroke-width="2.5"
            />
            {/* Subtle highlight on body to suggest chrome without a
                multi-stop gradient. */}
            <rect
              x="64"
              y="60"
              width="72"
              height="6"
              rx="3"
              fill="#fdf6e0"
              opacity="0.7"
            />

            {/* Single wide bread slot across the top */}
            <rect
              x="68"
              y="50"
              width="64"
              height="8"
              rx="2"
              fill="#1a0a08"
              stroke="#0f2e3d"
              stroke-width="1.5"
            />
            {/* slot divider — splits it visually into two bays */}
            <rect x="98" y="50" width="4" height="8" fill="#0f2e3d" />

            {/* Two toast slices popping up at staggered heights */}
            <rect
              x="71"
              y="26"
              width="24"
              height="26"
              rx="2"
              fill="#d8923a"
              stroke="#0f2e3d"
              stroke-width="2"
            />
            <rect
              x="105"
              y="34"
              width="24"
              height="18"
              rx="2"
              fill="#d8923a"
              stroke="#0f2e3d"
              stroke-width="2"
            />
            {/* Toasted-top stripes */}
            <rect x="74" y="29" width="18" height="3" rx="1" fill="#a85f1a" opacity="0.6" />
            <rect x="108" y="37" width="18" height="3" rx="1" fill="#a85f1a" opacity="0.6" />

            {/* Front: just a single gold lever knob, no extra noise */}
            <circle
              cx="125"
              cy="100"
              r="5"
              fill="#d4a843"
              stroke="#0f2e3d"
              stroke-width="1.5"
            />

            {/* Bottom shadow */}
            <ellipse cx="100" cy="132" rx="40" ry="3" fill="#0f2e3d" opacity="0.4" />
          </svg>
        ) : (
          <svg
            class="toasters__svg toasters__svg--toast"
            viewBox="0 0 100 100"
            xmlns="http://www.w3.org/2000/svg"
          >
            {/* Bread silhouette — single shape, single fill, strong outline.
                The dome-on-rectangle reads as a slice at any size. */}
            <path
              d="M 18 36
                 Q 18 14, 50 14
                 Q 82 14, 82 36
                 L 82 84
                 Q 82 88, 78 88
                 L 22 88
                 Q 18 88, 18 84 Z"
              fill="#dc923a"
              stroke="#0f2e3d"
              stroke-width="2.5"
            />
            {/* Crust line inset along the dome — gives the slice depth
                without a second fill. */}
            <path
              d="M 24 36 Q 24 20, 50 20 Q 76 20, 76 36"
              fill="none"
              stroke="#7a3a10"
              stroke-width="2"
              opacity="0.55"
            />
            {/* Two minimalist toast pores — enough to read as toasted bread. */}
            <circle cx="40" cy="58" r="2.5" fill="#7a3a10" opacity="0.5" />
            <circle cx="62" cy="68" r="2" fill="#7a3a10" opacity="0.5" />
          </svg>
        )}
      </span>
    ))
  }
</div>
