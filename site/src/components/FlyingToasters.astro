---
// Flying Toasters — original After Dark sprite art, layered above
// the Star Nest shader background.
//
// Sprite GIFs (toaster-sprite.gif, toast.gif): © Berkeley Systems Inc.,
// 1989. Vendored at site/public/sprites/ from
// https://github.com/bryanbraun/after-dark-css (gh-pages/img/).
//
// Animation recipe (steps()-flicker for wing flap composed with a
// translate keyframe for diagonal flight; "speed" classes t1..t9 +
// tst1..tst4 and "position" classes p6..p33): adapted verbatim from
// bryanbraun/after-dark-css's flying-toasters.html, MIT-licensed for
// HTML/CSS. See https://bryanbraun.github.io/after-dark-css/.
//
// Reduced-motion: animations stop entirely. Sprites stay scattered
// at their starting positions so the field still reads as
// decorative.

const base = import.meta.env.BASE_URL.replace(/\/$/, "")
const toasterSrc = `${base}/sprites/toaster-sprite.gif`
const toastSrc = `${base}/sprites/toast.gif`
---

<div
  class="toasters"
  aria-hidden="true"
  style={`--toaster-src: url(${toasterSrc}); --toast-src: url(${toastSrc});`}
>
  {/* First group of objects */}
  <div class="toaster t1 p6"></div>
  <div class="toaster t3 p7"></div>
  <div class="toast tst1 p8"></div>
  <div class="toaster t3 p9"></div>
  <div class="toaster t1 p11"></div>
  <div class="toaster t3 p12"></div>
  <div class="toaster t2 p13"></div>
  <div class="toast tst3 p14"></div>
  <div class="toast tst2 p16"></div>
  <div class="toaster t1 p17"></div>
  <div class="toast tst2 p19"></div>
  <div class="toast tst3 p20"></div>
  <div class="toaster t2 p21"></div>
  <div class="toast tst1 p24"></div>
  <div class="toaster t1 p22"></div>
  <div class="toast tst2 p26"></div>
  <div class="toaster t1 p28"></div>
  <div class="toast tst2 p30"></div>
  <div class="toaster t2 p31"></div>
  <div class="toaster t1 p32"></div>
  <div class="toast tst3 p33"></div>

  {/* Wave 1 — fast delayed */}
  <div class="toaster t4 p27"></div>
  <div class="toaster t4 p10"></div>
  <div class="toaster t4 p25"></div>
  <div class="toaster t4 p29"></div>

  {/* Wave 2 — common-speed delayed */}
  <div class="toaster t5 p15"></div>
  <div class="toaster t5 p18"></div>
  <div class="toaster t5 p22"></div>

  {/* Wave 3 */}
  <div class="toaster t6 p6"></div>
  <div class="toaster t6 p11"></div>
  <div class="toaster t6 p15"></div>
  <div class="toaster t6 p19"></div>
  <div class="toaster t6 p23"></div>

  {/* Wave 4 */}
  <div class="toast tst4 p10"></div>
  <div class="toast tst4 p23"></div>
  <div class="toast tst4 p15"></div>
  <div class="toaster t7 p7"></div>
  <div class="toaster t7 p12"></div>
  <div class="toaster t7 p16"></div>
  <div class="toaster t7 p20"></div>
  <div class="toaster t7 p24"></div>

  {/* Wave 5 */}
  <div class="toaster t8 p8"></div>
  <div class="toaster t8 p13"></div>
  <div class="toaster t8 p17"></div>
  <div class="toaster t8 p25"></div>

  {/* Wave 6 */}
  <div class="toaster t9 p14"></div>
  <div class="toaster t9 p18"></div>
  <div class="toaster t9 p21"></div>
  <div class="toaster t9 p26"></div>
</div>

<style>
  .toasters {
    position: fixed;
    inset: 0;
    /* Above the Star Nest canvas (z-index 0), below main (z-index 1+
       set in global.css for skip-link/main). */
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .toaster,
  .toast {
    position: absolute;
    width: 64px;
    height: 64px;
    image-rendering: pixelated;
  }

  .toaster {
    background-image: var(--toaster-src);
  }

  .toast {
    background-image: var(--toast-src);
  }

  /* Speed / flap-direction classes. The 4-frame wing-flap sprite is
     256 px wide; steps(4) cycles through it in increments of 64 px. */
  .t1 {
    animation:
      flap 0.2s steps(4) infinite alternate,
      fly 10s linear infinite;
  }
  .t2 {
    animation:
      flap 0.2s steps(4) infinite alternate-reverse,
      fly 16s linear infinite;
  }
  .t3 {
    animation:
      flap 0.2s steps(4) infinite alternate,
      fly 24s linear infinite;
  }
  .t4 {
    animation:
      flap 0.2s steps(4) infinite alternate,
      fly 10s 5s linear infinite;
  }
  .t5 {
    animation:
      flap 0.2s steps(4) infinite alternate-reverse,
      fly 24s 4s linear infinite;
  }
  .t6 {
    animation:
      flap 0.2s steps(4) infinite alternate,
      fly 24s 8s linear infinite;
  }
  .t7 {
    animation:
      flap 0.2s steps(4) infinite alternate-reverse,
      fly 24s 12s linear infinite;
  }
  .t8 {
    animation:
      flap 0.2s steps(4) infinite alternate,
      fly 24s 16s linear infinite;
  }
  .t9 {
    animation:
      flap 0.2s steps(4) infinite alternate-reverse,
      fly 24s 20s linear infinite;
  }

  /* Toast: fly only; no wings to flap. */
  .tst1 {
    animation: fly 10s linear infinite;
  }
  .tst2 {
    animation: fly 16s linear infinite;
  }
  .tst3 {
    animation: fly 24s linear infinite;
  }
  .tst4 {
    animation: fly 24s 12s linear infinite;
  }

  /*
   * Starting positions — sprites enter from the top edge and right
   * edge, organized into reverse-L batches so something is entering
   * the viewport at every moment of every cycle. Using percentages
   * so the field self-scales to viewport dimensions.
   */

  /* Batch 1 — top edge, right to left */
  .p6 {
    right: -2%;
    top: -17%;
  }
  .p7 {
    right: 10%;
    top: -19%;
  }
  .p8 {
    right: 20%;
    top: -18%;
  }
  .p9 {
    right: 30%;
    top: -20%;
  }
  .p10 {
    right: 40%;
    top: -21%;
  }
  .p11 {
    right: 50%;
    top: -18%;
  }
  .p12 {
    right: 60%;
    top: -20%;
  }
  /* Right edge, top to bottom */
  .p13 {
    right: -17%;
    top: 10%;
  }
  .p14 {
    right: -19%;
    top: 20%;
  }
  .p15 {
    right: -21%;
    top: 30%;
  }
  .p16 {
    right: -23%;
    top: 50%;
  }
  .p17 {
    right: -25%;
    top: 70%;
  }

  /* Batch 2 — further off-screen */
  .p18 {
    right: 0%;
    top: -26%;
  }
  .p19 {
    right: 10%;
    top: -20%;
  }
  .p20 {
    right: 20%;
    top: -36%;
  }
  .p21 {
    right: 30%;
    top: -24%;
  }
  .p22 {
    right: 40%;
    top: -33%;
  }
  .p23 {
    right: 60%;
    top: -40%;
  }
  .p24 {
    right: -26%;
    top: 10%;
  }
  .p25 {
    right: -36%;
    top: 30%;
  }
  .p26 {
    right: -29%;
    top: 50%;
  }

  /* Batch 3 — deepest offset */
  .p27 {
    right: 0;
    top: -46%;
  }
  .p28 {
    right: 10%;
    top: -56%;
  }
  .p29 {
    right: 20%;
    top: -49%;
  }
  .p30 {
    right: 30%;
    top: -60%;
  }
  .p31 {
    right: -46%;
    top: 10%;
  }
  .p32 {
    right: -56%;
    top: 20%;
  }
  .p33 {
    right: -49%;
    top: 30%;
  }

  /* Wing flap — cycles through the 4 frames of the 256 px sprite. */
  @keyframes flap {
    from {
      background-position: 0px;
    }
    to {
      background-position: -256px;
    }
  }

  /*
   * Diagonal glide. 1600 px translation handles the largest
   * reasonable viewport diagonals; sprites that exit early just
   * keep translating off-screen until the cycle restarts.
   */
  @keyframes fly {
    from {
      transform: translate(0, 0);
    }
    to {
      transform: translate(-1600px, 1600px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toaster,
    .toast {
      animation: none !important;
    }
  }
</style>
