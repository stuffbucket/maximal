#!/bin/sh
# max — run a downstream tool against the local Maximal proxy.
#
# Injects the Anthropic-shaped and OpenAI-shaped env vars that
# Claude Code, opencode, AI SDK, Cursor's CLI, etc. all read on
# startup, then exec's the target. The proxy listens on
# http://127.0.0.1:4141 and the per-launch shell API key is pulled
# from the running sidecar via `maximal print-shell-key`.
#
# Usage:
#   max claude
#   max claude "summarize this repo"
#   max opencode run "..."
#   max -- printenv ANTHROPIC_BASE_URL    # `--` escape; useful for debugging
#
# Exit codes:
#   1   maximal is not on PATH or not running
#   2   proxy running standalone — no per-launch shell key available
#   *   propagated from the wrapped command

set -e

if [ "$#" -eq 0 ]; then
  cat >&2 <<'EOF'
usage: max <tool> [args...]

Runs <tool> with these env vars pre-set against the local Maximal proxy:

  ANTHROPIC_BASE_URL = http://127.0.0.1:4141
  ANTHROPIC_API_KEY  = <per-launch shell key>
  OPENAI_BASE_URL    = http://127.0.0.1:4141/v1
  OPENAI_API_KEY     = <per-launch shell key>

Requires `maximal` to be on PATH and the Maximal menubar app
(or `maximal start`) to be running.
EOF
  exit 64
fi

if ! command -v maximal >/dev/null 2>&1; then
  echo "max: 'maximal' is not on PATH. Install Maximal first." >&2
  exit 1
fi

# `print-shell-key` writes diagnostics to stderr and exits non-zero
# if the proxy isn't running or has no shell key. Surface its message
# as-is so users know exactly what to fix.
KEY="$(maximal print-shell-key)" || exit $?

# `--` escape lets users debug with arbitrary commands without
# `max` interpreting them as a tool name.
if [ "$1" = "--" ]; then
  shift
fi

exec env \
  ANTHROPIC_BASE_URL="http://127.0.0.1:4141" \
  ANTHROPIC_API_KEY="$KEY" \
  OPENAI_BASE_URL="http://127.0.0.1:4141/v1" \
  OPENAI_API_KEY="$KEY" \
  "$@"
