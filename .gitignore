node_modules/
dist/
# build/ holds two flavors: compiled output (bun-build artifacts —
# ignore) and source-controlled installer templates under
# build/macos/ and build/homebrew/. The pattern below ignores
# everything in build/ except those source trees.
build/*
!build/macos/
!build/homebrew/
!build/windows/
SBOM.cdx.json
*.log
.DS_Store
.env
.env.local
.env.*.local

# bun
.bun/

# editor
.vscode/
.idea/
*.swp

# from upstream caozhiyuan/copilot-api
# local env
*.local
# aider
.aider*
# eslint cache
.eslintcache
.opencode/plans
.opencode/package-lock.json
*.vsix
.claude

# Stray runtime config dir created by accidentally running the proxy
# with COPILOT_API_HOME pointing at a relative path. Keep it ignored
# at the repo level so an errant misconfig can't slip into a commit
# (it lives outside the repo on a correctly configured host).
/foo/

