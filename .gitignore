node_modules/
dist/
# build/ holds two flavors: compiled output (bun-build artifacts —
# ignore) and source-controlled installer templates under
# build/macos/. The pattern below ignores everything in build/ except
# the macos source tree.
build/*
!build/macos/
SBOM.cdx.json
*.log
.DS_Store
.env
.env.local
.env.*.local

# bun
.bun/

# editor
.vscode/
.idea/
*.swp

# from upstream caozhiyuan/copilot-api
# local env
*.local
# aider
.aider*
# eslint cache
.eslintcache
.opencode/plans
.opencode/package-lock.json
*.vsix
.claude

