#!/bin/bash
# Self-installer for maximal.app. Runs every time the user
# double-clicks the .app from /Applications.
#
# Behavior is idempotent — re-launches just refresh the binary and
# the launchd agent. The .app stays in /Applications; this shim
# copies the binary out to ~/.local/bin/maximal and registers
# the launchd plist so the proxy starts on login.
#
# Spec: docs/spec/internal-distribution-stream-b.md §7.

set -euo pipefail

APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BIN_SRC="$APP_DIR/MacOS/maximal"
PLIST_SRC="$APP_DIR/Resources/co.stuffbucket.maximal.plist"

INSTALL_BIN="$HOME/.local/bin/maximal"
INSTALL_PLIST="$HOME/Library/LaunchAgents/co.stuffbucket.maximal.plist"

LABEL="co.stuffbucket.maximal"
DOMAIN="gui/$(id -u)"

if [ ! -x "$BIN_SRC" ]; then
  /usr/bin/osascript -e \
    "display alert \"maximal install failed\" message \"Bundled binary missing at $BIN_SRC. Reinstall the .app from the DMG.\""
  exit 1
fi

# Install binary + plist (idempotent — overwrite any older install).
mkdir -p "$(dirname "$INSTALL_BIN")" "$(dirname "$INSTALL_PLIST")"
cp -f "$BIN_SRC" "$INSTALL_BIN"
chmod 755 "$INSTALL_BIN"

# The plist template carries __HOME__ and __INSTALL_BIN__ sentinels —
# substitute them with the resolved paths so launchd reads absolute
# strings. Using a temp file + mv keeps the rewrite atomic.
TMP_PLIST="$(mktemp)"
sed \
  -e "s|__HOME__|$HOME|g" \
  -e "s|__INSTALL_BIN__|$INSTALL_BIN|g" \
  "$PLIST_SRC" > "$TMP_PLIST"
mv -f "$TMP_PLIST" "$INSTALL_PLIST"

# Make sure ~/.local/bin is on the user's interactive shell PATH. The
# binary copy above lands in ~/.local/bin/maximal, but a fresh-account
# macOS user's zsh has no reason to look there. We append a marker-
# guarded block to both ~/.zshrc (interactive) and ~/.zprofile (login)
# so new terminals pick it up. The current dock launch has no shell to
# source into — that's fine; this is for the *next* terminal window.
# Bash is intentionally skipped: zsh has been macOS's default since
# Catalina (2019).
PATH_MARKER_START="# >>> maximal PATH >>>"
PATH_MARKER_END="# <<< maximal PATH <<<"
PATH_BLOCK="$PATH_MARKER_START
export PATH=\"\$HOME/.local/bin:\$PATH\"
$PATH_MARKER_END"

for rc in "$HOME/.zshrc" "$HOME/.zprofile"; do
  touch "$rc"
  if ! grep -qF "$PATH_MARKER_START" "$rc"; then
    printf '\n%s\n' "$PATH_BLOCK" >> "$rc"
  fi
done

# Make sure the log dir referenced in the plist exists, otherwise
# launchd will refuse to bootstrap.
mkdir -p "$HOME/Library/Logs/maximal"

# (Re)load the launch agent. bootout fails if the agent isn't loaded;
# swallow that case — the goal is "loaded with current plist."
launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
launchctl bootstrap "$DOMAIN" "$INSTALL_PLIST"

# Run B5 in unattended mode. --skip-auth: the device-code flow needs
# an interactive shell, which we don't have here. The user runs
# `maximal setup` from a terminal once after install.
"$INSTALL_BIN" setup --unattended --skip-auth || true

# Notify and exit. The launchd agent is now running the actual proxy.
/usr/bin/osascript -e \
  "display notification \"Run \\\"maximal setup\\\" once from Terminal to authenticate with GitHub.\" with title \"maximal installed\""
exit 0
