<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-user, CLI-only MSI for the maximal command-line binary.

  WiX 4 / 5 syntax. Built in CI on windows-2022 via:

    dotnet tool install (global) wix
    wix build build/windows/maximal.wxs (with) -d Version=x.y.z -arch x64 -o output.msi

  The minted MSI:

    - Installs maximal.exe to %LocalAppData%\Programs\maximal (per-user;
      no UAC prompt, no admin needed).
    - Adds the install dir to the user's PATH.
    - Registers an Add/Remove Programs entry (MajorUpgrade + UpgradeCode)
      so upgrades and uninstall work.

  This is the CLI installer ONLY. It deliberately does NOT register a
  scheduled task, run `maximal setup`, or drop a Start Menu shortcut. The
  Tauri tray app (the separate NSIS installer,
  maximal-<ver>-windows-x64-setup.exe) is the canonical Windows experience
  and owns running the proxy, auto-start, and first-run setup — exactly
  like the macOS menu-bar app. Keeping the MSI to "binary on PATH" avoids
  a console `maximal setup` Start Menu entry that looked like an app
  launcher, and removes the WiX Util custom actions (no `-ext` needed).

  Ships unsigned (A4 deferred). SmartScreen prompts on first run.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
      Name="maximal"
      Manufacturer="stuffbucket"
      Version="$(var.Version)"
      UpgradeCode="C9E7F4A1-2B3D-4E5F-9A8B-7C6D5E4F3A2B"
      Scope="perUser"
      InstallerVersion="500"
      Compressed="yes">

    <SummaryInformation
        Description="Local proxy that exposes GitHub Copilot as the Anthropic / OpenAI API"
        Manufacturer="stuffbucket" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="maximal" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!--
      Stop any running copy of maximal.exe before files are touched, so an
      upgrade doesn't hit the MSI "files in use" prompt while the running
      .exe holds the file lock. taskkill returns 128 when nothing matches;
      Return="ignore" treats 0 and 128 as success. SystemFolder resolves
      to C:\Windows\System32 at run time.
    -->
    <CustomAction
        Id="StopRunningMaximal"
        Directory="SystemFolder"
        ExeCommand="taskkill.exe /F /IM maximal.exe /T"
        Execute="immediate"
        Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="StopRunningMaximal" Before="InstallValidate" />
    </InstallExecuteSequence>

  </Package>

  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="maximal" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Bitness="always64">
        <File
            Id="maximal_exe"
            Source="maximal.exe"
            KeyPath="yes" />
        <Environment
            Id="UpdatePath"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="no" />
      </Component>
      <!--
        Per-user HKCU keypath that doubles as an "installed" marker the
        Windows installer dev harness asserts. Its own component so it has
        a registry keypath independent of the file.
      -->
      <Component Id="InstalledMarker" Bitness="always64">
        <RegistryValue
            Root="HKCU"
            Key="Software\stuffbucket\maximal"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
