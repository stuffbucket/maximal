<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-user MSI for maximal.

  WiX 4 / 5 syntax. Built in CI on windows-2022 via:

    dotnet tool install (global) wix
    wix build build/windows/maximal.wxs (with) -d Version=x.y.z -arch x64 -o output.msi

  XML comments can't contain consecutive dashes, so flag prose is
  paraphrased; see installers.yml for the real invocation.

  No third-party GitHub Action involved: `dotnet` is preinstalled on
  the runner image, and WiX is a dotnet tool. The minted MSI:

    - Installs to %LocalAppData%\Programs\maximal (per-user; no
      UAC prompt, no admin needed).
    - Adds the install dir to the user's PATH.
    - Drops a Start Menu shortcut to `maximal setup` so the user
      has a discoverable post-install step.
    - Registers an Add/Remove Programs entry with proper version /
      manufacturer / upgrade-code so MajorUpgrade re-installs work.

  The MSI converges with B3a's PowerShell installer (install.ps1):
  both register an at-logon scheduled task that runs `maximal start`,
  run `maximal setup` unattended (skip-auth) for the Claude Desktop
  config touches, AND leave a discoverable `maximal setup` Start Menu
  shortcut + Add/Remove Programs entry. The scheduled task + setup run
  as deferred, impersonated custom actions (schtasks.exe / the .exe
  itself) so they touch the *installing user's* per-user state. All are
  Return="ignore": a flaky setup or task registration must not roll
  back an otherwise-good install (the user can always re-run `maximal
  setup` from the Start Menu shortcut). XML comments can't contain
  consecutive dashes, so CLI flag prose is paraphrased above.

  v1 ships unsigned (A4 deferred). SmartScreen prompts on first run;
  the Pages landing site (B4) documents the bypass.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
      Name="maximal"
      Manufacturer="stuffbucket"
      Version="$(var.Version)"
      UpgradeCode="C9E7F4A1-2B3D-4E5F-9A8B-7C6D5E4F3A2B"
      Scope="perUser"
      InstallerVersion="500"
      Compressed="yes">

    <SummaryInformation
        Description="Local proxy that exposes GitHub Copilot as the Anthropic / OpenAI API"
        Manufacturer="stuffbucket" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="maximal" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="StartMenuComponents" />
    </Feature>

    <!--
      Stop any running copy of maximal.exe before files are touched.
      Without this, install / upgrade / uninstall hits the MSI
      "files in use" prompt the moment the running .exe holds the
      file lock, and a port-bound maximal blocks `maximal start`
      after install with EADDRINUSE on 4141.

      taskkill returns 128 when the process isn't running; Return
      "ignore" treats both 0 and 128 as success. SystemFolder
      resolves to C:\Windows\System32 at runtime so this works on
      every install path.
    -->
    <CustomAction
        Id="StopRunningMaximal"
        Directory="SystemFolder"
        ExeCommand="taskkill.exe /F /IM maximal.exe /T"
        Execute="immediate"
        Return="ignore" />

    <!--
      Register the at-logon scheduled task that runs `maximal start`.
      Mirrors install.ps1's Register-StartupTask. schtasks /Create with
      /SC ONLOGON registers a per-user task that runs in the installing
      user's session. /RL LIMITED keeps it non-elevated (per-user
      install needs no admin). /F overwrites an existing task so
      upgrades/re-installs are idempotent. /IT runs only when the user
      is logged on (this is a per-user proxy). Deferred + Impersonate so
      it lands in the installing user's task store, not SYSTEM's.

      We pre-compute the command line into a property so it survives the
      immediate->deferred boundary (deferred CAs can't read INSTALLFOLDER
      directly). %LocalAppData% is expanded by schtasks at run time.
    -->
    <CustomAction
        Id="SetRegisterTaskCmd"
        Property="RegisterStartupTask"
        Value="&quot;[SystemFolder]schtasks.exe&quot; /Create /TN maximal /TR &quot;\&quot;[INSTALLFOLDER]maximal.exe\&quot; start&quot; /SC ONLOGON /RL LIMITED /IT /F"
        Execute="immediate" />
    <CustomAction
        Id="RegisterStartupTask"
        BinaryRef="Wix4UtilCA_X64"
        DllEntry="WixQuietExec64"
        Execute="deferred"
        Impersonate="yes"
        Return="ignore" />

    <!--
      Run first-run setup unattended (Claude Desktop config touches; no
      GitHub auth — that needs an interactive device-code flow, which a
      silent install can't provide). Mirrors install.ps1 step 6.
    -->
    <CustomAction
        Id="SetRunSetupCmd"
        Property="RunUnattendedSetup"
        Value="&quot;[INSTALLFOLDER]maximal.exe&quot; setup --unattended --skip-auth"
        Execute="immediate" />
    <CustomAction
        Id="RunUnattendedSetup"
        BinaryRef="Wix4UtilCA_X64"
        DllEntry="WixQuietExec64"
        Execute="deferred"
        Impersonate="yes"
        Return="ignore" />

    <!--
      Tear the scheduled task down on uninstall. immediate + the running
      .exe is already killed by StopRunningMaximal. schtasks /Delete
      returns non-zero if the task is absent; Return="ignore" absorbs it.
    -->
    <CustomAction
        Id="DeleteStartupTask"
        Directory="SystemFolder"
        ExeCommand="schtasks.exe /Delete /TN maximal /F"
        Execute="immediate"
        Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="StopRunningMaximal" Before="InstallValidate" />
      <!-- Tear down before files vanish, only on a real uninstall. -->
      <Custom Action="DeleteStartupTask" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
      <!-- Set the deferred command lines, then run them after files land. -->
      <Custom Action="SetRegisterTaskCmd" Before="RegisterStartupTask"
              Condition="NOT REMOVE" />
      <Custom Action="RegisterStartupTask" After="InstallFiles"
              Condition="NOT REMOVE" />
      <Custom Action="SetRunSetupCmd" Before="RunUnattendedSetup"
              Condition="NOT REMOVE" />
      <Custom Action="RunUnattendedSetup" After="RegisterStartupTask"
              Condition="NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>

  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="maximal" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="maximal" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Bitness="always64">
        <File
            Id="maximal_exe"
            Source="maximal.exe"
            KeyPath="yes" />
        <Environment
            Id="UpdatePath"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="no" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="StartMenuComponents" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut
            Id="SetupShortcut"
            Name="maximal setup"
            Description="Run first-time setup (GitHub auth + Claude Desktop config)"
            Target="[INSTALLFOLDER]maximal.exe"
            Arguments="setup"
            WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveAppMenuFolder" On="uninstall" />
        <RegistryValue
            Root="HKCU"
            Key="Software\stuffbucket\maximal"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
