{
  "name": "copilot-api-desktop",
  "version": "1.0.0",
  "description": "Copilot API Desktop App",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:server": "npm --prefix .. run build:desktop",
    "preview": "electron-vite preview",
    "gen-icons": "rsvg-convert -w 1024 -h 1024 assets/tray-icon-colored.svg -o assets/icon.png",
    "package": "npm run build:server && electron-vite build && electron-builder",
    "package:mac": "npm run build:server && electron-vite build && electron-builder --mac",
    "package:win": "npm run build:server && electron-vite build && electron-builder --win",
    "package:linux": "npm run build:server && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "build": {
    "appId": "com.copilot-api.desktop",
    "productName": "Copilot API",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "server",
        "filter": ["**/*.js"]
      },
      {
        "from": "../pages",
        "to": "pages"
      },
      {
        "from": "build/server-package.json",
        "to": "server/package.json"
      },
      {
        "from": "assets/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "assets/tray-icon@2x.png",
        "to": "tray-icon@2x.png"
      },
      {
        "from": "assets/tray-iconTemplate.png",
        "to": "tray-iconTemplate.png"
      },
      {
        "from": "assets/tray-iconTemplate@2x.png",
        "to": "tray-iconTemplate@2x.png"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png"
    },
    "dmg": {
      "format": "ULFO"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/vite": "^4.1.4",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.3.3"
  }
}
